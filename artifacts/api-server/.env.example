# API Server Environment Variables (Copy to .env.local or Vercel)
# Replace values with your actual Supabase credentials

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_your_service_role_key
DATABASE_URL=postgresql://postgres:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
API_BASE_URL=https://your-api.vercel.app/api
LOG_LEVEL=info
NODE_ENV=production
